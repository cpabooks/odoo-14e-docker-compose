<?xml version="1.0" encoding="UTF-8" ?>

<odoo>

    <record id="mrp_production_view_form_inherit_gp" model="ir.ui.view">
        <field name="name">mrp.production.view.form.inherit.gp</field>
        <field name="model">mrp.production</field>
        <field name="inherit_id" ref="mrp.mrp_production_form_view"/>
        <field name="arch" type="xml">

            <xpath expr="//page[@name='components']//field[@name='move_raw_ids']//tree//field[@name='product_uom']"
                   position="after">
                <field name="perfume_type"/>
                <field name="perfume_packaging"/>
                <field name="percentage"/>
                <field name="remarks"/>
            </xpath>

        </field>
    </record>

</odoo>