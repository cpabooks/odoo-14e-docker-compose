+            <field name="type">account_type</field>
+            <field name="account_type_ids"
+                   eval="[(4,ref('account.data_account_type_expenses')), (4,ref('account.data_account_type_direct_costs')), (4,ref('account.data_account_type_depreciation'))]"/>
