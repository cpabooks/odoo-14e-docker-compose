+     /**
+     * @override
+     * @param {string} handle
+     * @param {number} proposition id (move line id)
+     * @returns {Promise}
+     */
+    removeProposition: function (handle, id) {
+        if (!id) {
+            return Promise.resolve();
+        }
+        return this._super(handle, id);
+    },
+    /**
+     * move the partner field
+     *
+     * @override
