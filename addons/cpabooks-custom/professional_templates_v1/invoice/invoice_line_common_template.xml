<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template id="invoice_lines_common_template">
            <div t-if="o.project_title and style.template_inv.key !='professional_templates_v1.INVOICE_13_document'"
                 class="col-12"
                 t-attf-style="color:{{style.theme_txt_color if not style.transparent else style.text_color}};text-align:center; padding-left:0px; padding-right:0px;">
                <div t-attf-style="width:auto; display:inline-block; background-color:{{style.theme_color if not style.transparent else 'transparent'}};padding-left:8px; padding-right:8px;">
                    <span t-attf-style="margin-top:8px; margin-bottom:8px;font-size:{{int(style.body_font)+4}}px;">
                        <span t-field="o.project_title"/>
                    </span>
                </div>
            </div>
            <div class="col-12 float-left" style="padding:8px;"/>

            <!-- Is there a discount on at least one line? -->
            <t t-set="display_discount" t-value="any([l.discount for l in o.invoice_line_ids])"/>
            <!-- Is there tax in at least one line? -->
            <t t-set="display_taxes" t-value="any([y.tax_ids for y in o.invoice_line_ids])"/>
            <!-- to take care of columns when no discount -->
            <t t-set="col_span" t-value="8 if display_discount else 7"/>

            <t t-set="td_style" t-value="'border: 1px solid #a6a6a6 !important;'"></t>
            <div name="subject" t-attf-style="margin-bottom:15px !important;" t-if="o.show_subject">
                <strong style="white-space:nowrap;">Subject:</strong>
                <span t-field="o.subject"/>
            </div>

            <table class="table table-sm" t-attf-style="color:{{style.text_color}};" name="invoice_line_table">
                <thead t-attf-style="color:{{style.theme_txt_color if not style.transparent else style.text_color}};">
                    <!--                    <t t-set="th_style" t-value="'border-bottom: 1px solid #ddd !important;white-space:nowrap;'"></t>-->
                    <t t-set="th_style"
                       t-value="'border: 1px solid #a6a6a6 !important;white-space:nowrap;;vertical-align:middle !important;'"></t>
                    <!--                    {{background_clr if not style.transparent else 'transparent'}}-->
                    <tr t-attf-style="background-color:{{background_clr}};font-size:{{int(style.body_font)+2}}px;">
                        <th name="count_th" t-attf-style="{{th_style}}">
                            <i class="fa fa-list-ol" t-if="not style.is_icon_hide"/>
                        </th>
                        <th name="image_th" t-if="style.show_img" t-attf-style="{{th_style}}">
                            <i class="fa fa-camera" t-if="not style.is_icon_hide"/>
                            Image
                        </th>
                        <th name="item_code_th" t-attf-style="{{th_style}}" t-if="style.is_item_code_visible">Item
                            Code
                        </th>
                        <th name="description_th" t-attf-style="{{th_style}}">
                            <i class="fa fa-th-large" t-if="not style.is_icon_hide"/>
                            Item &amp; Description
                        </th>
                        <th name="source_th" t-attf-style="{{th_style}}" class="d-none text-left">
                            <i class="fa fa-th-large" t-if="not style.is_icon_hide"/>
                            Source Document
                        </th>
                        <th name="qty_th" class="text-right" t-attf-style="{{th_style}}">
                            <i class="fa fa-sort-amount-asc" t-if="not style.is_icon_hide"/>
                            Qty
                            <br/>
                            <span>Unit</span>
                        </th>
                        <!--                        <th class="text-right" t-attf-style="{{th_style}}"><i class="fa fa-sort-amount-asc"/> Units</th>-->
                        <th name="unit_price_th" class="text-center" t-attf-style="{{th_style}}">Unit
                            <br/>
                            <span>Price</span>
                        </th>
                        <!--                        <th name="total_amount_th" class="text-center" t-attf-style="{{th_style}}">Total <br/><span>Amount</span></th>-->
                        <th name="total_amount_th" class="text-center" t-attf-style="{{th_style}}">Amount
                            <br/>
                            <span>Excl. Tax</span>
                        </th>

                        <th name="own_discount_th" t-if="display_discount" class="text-right"
                            t-attf-style="{{th_style}}"
                            groups="product.group_discount_per_so_line">Discount(%)
                        </th>

                        <th name="tax_th" t-if="display_taxes" class="text-center" t-attf-style="{{th_style}}">Tax
                            <br/>
                            <span>%</span>
                        </th>
                        <th name="tax_amount_th" t-if="display_taxes" class="text-center" t-attf-style="{{th_style}}">
                            Tax
                            <br/>
                            <span>Amount</span>
                        </th>
                        <th name="amnt_incl_amount_th" class="text-right" t-attf-style="{{th_style}}"
                            t-if="display_taxes">
                            <span groups="account.group_show_line_subtotals_tax_excluded">Amount
                                <br/>
                                <span>Incl. Tax</span>
                            </span>
                            <span groups="account.group_show_line_subtotals_tax_included">Total
                                <br/>
                                <span>Price</span>
                            </span>
                        </th>
                    </tr>
                </thead>
                <tbody t-attf-style="color:{{style.text_color}};">
                    <t t-set="current_subtotal" t-value="0.0"/>
                    <t t-set="total_tax_amt" t-value="0.0"/>
                    <t t-set="item_count" t-value="0"/>
                    <t t-set="total_amntincltax_amt" t-value="0.0"/>
                    <t t-set="total_amount_excluding_tax" t-value="0.0"/>

                    <t t-foreach="o.invoice_line_ids" t-as="l">

                        <!-- Safe tax calculation -->
                        <t t-set="tax_amount" t-value="l.calculate_tax_amt() or 0.0"/>
                        <t t-set="after_discount_amount" t-value="l.get_after_discount_amt() or 0.0"/>
                        <t t-set="check_tax_included_or_excluded" t-value="l.check_tax_type()"/>

                        <!-- Safe unit price logic -->
                        <t t-if="not check_tax_included_or_excluded">
                            <t t-set="unit_price" t-value="l.price_unit or 0.0"/>
                        </t>
                        <t t-else="">
                            <t t-set="unit_price"
                               t-value="(l.price_unit or 0.0) - ((tax_amount / l.quantity) if l.quantity else 0.0)"/>
                        </t>

                        <!-- Safe amount calculations -->
                        <t t-set="amount_excluding_tax" t-value="(unit_price or 0.0) * (l.quantity or 0.0)"/>
                        <t t-set="total_amount_excluding_tax"
                           t-value="total_amount_excluding_tax + (amount_excluding_tax or 0.0)"/>

                        <t t-set="item_count" t-value="item_count + 1"/>

                        <!-- Safe subtotal accumulation -->
                        <t groups="account.group_show_line_subtotals_tax_excluded"
                           t-set="current_subtotal"
                           t-value="current_subtotal + (l.price_subtotal or 0.0)"/>

                        <t groups="account.group_show_line_subtotals_tax_included"
                           t-set="current_subtotal"
                           t-value="current_subtotal + (l.price_total or 0.0)"/>

                        <t t-set="total_tax_amt"
                           t-value="total_tax_amt + (tax_amount or 0.0)"/>

                        <!-- Safe price subtotal -->
                        <t t-if="not check_tax_included_or_excluded"
                           t-set="price_subtotal"
                           t-value="(after_discount_amount or 0.0) + (tax_amount or 0.0)"/>

                        <t t-else=""
                           t-set="price_subtotal"
                           t-value="(l.price_subtotal or 0.0) + (tax_amount or 0.0)"/>

                        <t t-set="total_amntincltax_amt"
                           t-value="total_amntincltax_amt + (price_subtotal or 0.0)"/>

                        <!-- Invoice Line Row -->
                        <tr style="page-break-inside: avoid">

                            <t t-if="not l.display_type">

                                <td>
                                    <span t-esc="item_count"/>
                                </td>

                                <td class="text-right">
                                    <span t-esc="l.quantity or 0.0"/>
                                </td>

                                <td class="text-right">
                                    <span t-esc="unit_price or 0.0"
                                          t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                </td>

                                <td class="text-right">
                                    <span t-esc="amount_excluding_tax or 0.0"
                                          t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                </td>

                                <td t-if="display_taxes" class="text-right">
                                    <span t-esc="tax_amount or 0.0"
                                          t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                </td>

                                <td t-if="display_taxes" class="text-right">
                                    <span t-esc="price_subtotal or 0.0"
                                          t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                </td>

                            </t>

                        </tr>

                    </t>

                    <!-- Grand Subtotal Row -->
                    <tr style="background-color:#d3d3d3; font-weight:bold;">
                        <td colspan="3">Sub Total</td>

                        <td class="text-right">
                            <span t-esc="total_amount_excluding_tax or 0.0"
                                  t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                        </td>

                        <td t-if="display_taxes" class="text-right">
                            <span t-esc="total_tax_amt or 0.0"
                                  t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                        </td>

                        <td t-if="display_taxes" class="text-right">
                            <span t-esc="total_amntincltax_amt or 0.0"
                                  t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                        </td>
                    </tr>

                </tbody>
            </table>
            <div class="row">
                <div class="col-7">
                    <div t-if="style.aiw_report">
                        <p>
                            <!--                    <strong>Amount in Words:</strong><span style="text-decoration:underline;" t-field="o.amount_words"/>-->
                            <strong>Amount In Words:</strong>
                            <span t-field="o.num_word"/>
                            <span>Only.</span>
                        </p>
                    </div>
                </div>
                <!--            <div id="total" t-attf-class="#{'col-4 float-right' if report_type != 'html' else 'col-sm-7 col-md-5 float-right'} ml-auto" t-attf-style="padding-right:8px;">-->
                <div id="total" class="col-5">
                    <table class="table table-sm" t-attf-style="color:{{style.text_color}} !important;">
                        <!--                    <tr class="border-black">-->
                        <tr name="sm_total_amount_tr" class="border-black">
                            <td>
                                <strong>Total Amount Excl. Tax</strong>
                            </td>
                            <td class="text-right">
                                <span t-field="o.amount_untaxed"
                                      t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                            </td>
                        </tr>
                        <t t-foreach="o.amount_by_group" t-as="amount_by_group">
                            <tr t-attf-style="color:{{style.text_color}} !important">
                                <t t-if="len(o.line_ids.filtered(lambda line: line.tax_line_id)) == 1 and o.amount_untaxed == amount_by_group[2]">
                                    <td>
                                        <span t-esc="amount_by_group[0]"/>
                                    </td>
                                    <td class="text-right">
                                        <span t-esc="amount_by_group[3]"/>
                                    </td>
                                </t>
                                <t t-else="">
                                    <td>
                                        <span t-esc="amount_by_group[0]"/>
                                        <!--                                    <span>&amp;nbsp;<span>on</span>-->
                                        <!--                                        <t t-esc="amount_by_group[4]"/>-->
                                        <!--                                    </span>-->
                                    </td>
                                    <td class="text-right">
                                        <span t-esc="amount_by_group[3]"/>
                                    </td>
                                </t>
                            </tr>
                        </t>
                        <tr name="sm_total_tr" class="border-black">
                            <!--                        <td t-attf-style="border-top: 1px solid {{style.text_color}} !important;"><strong>Total</strong></td>-->
                            <td>
                                <strong>Total Invoice Amount</strong>
                            </td>
                            <td class="text-right">
                                <!--                            text-decoration:underline;-->
                                <span style="font-weight:bold;" t-field="o.amount_total"/>
                            </td>
                        </tr>

                        <t t-set="print_with_payments" t-value="True"/>
                        <t t-if="print_with_payments">
                            <t t-if="o.payment_state != 'invoicing_legacy'">
                                <t t-set="payments_vals" t-value="o.sudo()._get_reconciled_info_JSON_values()"/>
                                <t t-foreach="payments_vals" t-as="payment_vals">
                                    <tr class="border-black">
                                        <td>
                                            <i class="oe_form_field text-right oe_payment_label">Paid on
                                                <t t-esc="payment_vals['date']" t-options='{"widget": "date"}'/>
                                            </i>
                                        </td>
                                        <td class="text-right">
                                            <span t-esc="payment_vals['amount']"
                                                  t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                        </td>
                                    </tr>
                                </t>
                                <t t-if="len(payments_vals) > 0">
                                    <tr class="border-black">
                                        <td>
                                            <strong>Amount Due</strong>
                                        </td>
                                        <td class="text-right">
                                            <span t-field="o.amount_residual"/>
                                        </td>
                                    </tr>
                                </t>
                            </t>
                        </t>
                    </table>
                </div>
                <!--            <div t-if="style.aiw_report" class="col-7 float-left" style="padding-left:0px; padding-right:0px; page-break-inside: avoid;">-->

            </div>

            <!--            <div class="col-12 float-left" style="padding-left:0px; padding-right:0px; page-break-inside: avoid;">-->
            <!--                <p t-if="o.move_type in ('out_invoice', 'in_refund') and o.payment_reference" name="payment_communication">-->
            <!--                        Please use the following communication for your payment : <b><span t-field="o.payment_reference"/></b>-->
            <!--                    </p>-->
            <!--                    <p t-if="o.invoice_payment_term_id" name="payment_term">-->
            <!--                        <span t-field="o.invoice_payment_term_id.note"/>-->
            <!--                    </p>-->
            <!--                    <p t-if="o.narration" name="comment">-->
            <!--                        <span t-field="o.narration"/>-->
            <!--                    </p>-->
            <!--                    <p t-if="o.fiscal_position_id.note" name="note">-->
            <!--                        <span t-field="o.fiscal_position_id.note"/>-->
            <!--                    </p>-->
            <!--                    <p t-if="o.invoice_incoterm_id" name="incoterm">-->
            <!--                        <strong>Incoterm: </strong><span t-field="o.invoice_incoterm_id.code"/> - <span t-field="o.invoice_incoterm_id.name"/>-->
            <!--                    </p>-->
            <!--                    <div id="qrcode" t-if="o.display_qr_code">-->
            <!--                        <p t-if="qr_code_urls.get(o.id)">-->
            <!--                            <strong class="text-center">Scan me with your banking app.</strong><br/><br/>-->
            <!--                            <img class="border border-dark rounded" t-att-src="qr_code_urls[o.id]"/>-->
            <!--                        </p>-->
            <!--                    </div>-->
            <!--                </div>-->
        </template>
        <!-- we can also add product image to odoo template -->
        <template id="add_image_to_odoo_template" inherit_id="account.report_invoice_document">
            <xpath expr="//thead//tr//th" position="before">
                <t t-set="style"
                   t-value="o.style or res_company.df_style or user.env.ref('customized_invoice.df_style_for_all_reports')"/>
                <th t-if="style.show_img">Image</th>
            </xpath>
            <xpath expr="//tbody[hasclass('invoice_tbody')]//tr//td" position="before">
                <td t-if="style.show_img">
                    <span t-if="line.sudo().product_id.image_128" itemprop="image"
                          t-field="line.sudo().product_id.image_128" t-options='{"widget": "image"}'/>
                </td>
            </xpath>
        </template>
    </data>
</odoo>
