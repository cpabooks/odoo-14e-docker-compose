<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="view_fsm_project_task_list_view_inherit" model="ir.ui.view">
            <field name="name">view.fsm.project.task.list.view.inherit</field>
            <field name="model">project.task</field>
            <field name="inherit_id" ref="industry_fsm.project_task_view_list_fsm"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='planned_date_begin']" position="replace">
                    <field name="date_start" optional="hide"/>
                </xpath>
                <xpath expr="//field[@name='planned_date_end']" position="replace">
                    <field name="date_end" optional="hide"/>
                </xpath>
                <xpath expr="//field[@name='stage_id']" position="attributes">
                    <attribute name="string">Activity</attribute>
                </xpath>
                <xpath expr="//field[@name='stage_id']" position="after">
                    <field name="state" readonly="1" optional="hide"/>
                </xpath>
            </field>
        </record>

        <record id="project_task_view_search_fsm_inherit_admin" model="ir.ui.view">
            <field name="name">project.task.search.fsm.inherit.admin</field>
            <field name="model">project.task</field>
            <field name="inherit_id" ref="industry_fsm.project_task_view_search_fsm"/>
            <field name="arch" type="xml">
                <xpath expr="//filter[@name='planned_future']" position="after">
                    <filter string="Waiting For Approval"
                            name="job_completed_invoiced"
                            domain="[('stage', '=', 'job_completed_invoiced')]"
                    />
                </xpath>
            </field>
        </record>

        <record id="industry_fsm.project_task_action_fsm" model="ir.actions.act_window">
            <field name="context">{
                'fsm_mode': True,
                'show_address': True,
                'search_default_my_tasks': False,
                'search_default_planned_future': False,
                'search_default_job_completed_invoiced': 1,
                'search_default_planned_today': False,
                'fsm_task_kanban_whole_date': False,
                }
            </field>
        </record>

        <menuitem id="menu_fsm_project_task_waiting" name="Waiting For Approval" parent="industry_fsm.fsm_tasks_menu" action="industry_fsm.project_task_action_fsm"/>

    </data>
</odoo>
