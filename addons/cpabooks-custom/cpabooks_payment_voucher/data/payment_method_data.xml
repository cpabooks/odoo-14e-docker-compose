<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Inbound Payment Method (For Customer Payments) -->
        <record id="payment_method_cpabooks_online" model="account.payment.method">
            <field name="name">Online Transfer</field>
            <field name="code">online_transfer</field>
            <field name="payment_type">inbound</field>
        </record>
        <record id="payment_method_cpabooks_cash_deposit" model="account.payment.method">
            <field name="name">Cash Deposit</field>
            <field name="code">cash_deposit</field>
            <field name="payment_type">inbound</field>
        </record>

        <record id="payment_method_cpabooks_cash" model="account.payment.method">
            <field name="name">Cash</field>
            <field name="code">cash</field>
            <field name="payment_type">inbound</field>
        </record>

        <record id="payment_method_cpabooks_outbound" model="account.payment.method">
            <field name="name">Cheque Deposit</field>
            <field name="code">check_deposit</field>
            <field name="payment_type">inbound</field>
        </record>
    </data>
</odoo>